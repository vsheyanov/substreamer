{
  "name": "substreamer",
  "version": "8.0.62",
  "license": "GPL-3.0-or-later",
  "main": "./index.js",
  "scripts": {
    "start": "expo start",
    "android": "source scripts/env-android.sh && expo run:android ${EXPO_ANDROID_DEVICE:+--device $EXPO_ANDROID_DEVICE}",
    "android:device": "source scripts/env-android.sh && expo run:android",
    "ios": "expo run:ios",
    "concurrent": "npx concurrently \"npm run ios\" \"npm run android\"",
    "prebuild": "expo prebuild --clean",
    "web": "expo start --web",
    "test": "jest",
    "validate:i18n": "node scripts/validate-translations.js",
    "validate:proguard": "node scripts/validate-proguard-rules.js",
    "validate:modules": "node scripts/validate-module-inventory.js",
    "test:watch": "jest --watchAll",
    "test:modules": "scripts/test-modules.sh",
    "build:modules": "scripts/build-modules.sh",
    "test:coverage": "jest --coverage --coverageReporters=text --coverageReporters=html",
    "generate-assets": "node scripts/generate-assets.js",
    "release": "node scripts/create-release.js",
    "release:patch": "node scripts/create-release.js patch",
    "release:minor": "node scripts/create-release.js minor",
    "release:major": "node scripts/create-release.js major",
    "reset-changelog": "node scripts/reset-store-changelog.js",
    "terminal-log": "script -a /tmp/claude-terminal.txt",
    "rebase": "git fetch origin && git rebase origin/master",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@formatjs/intl-datetimeformat": "^7.4.1",
    "@formatjs/intl-getcanonicallocales": "^3.2.5",
    "@formatjs/intl-locale": "^5.3.4",
    "@formatjs/intl-numberformat": "^9.3.4",
    "@formatjs/intl-pluralrules": "^6.3.4",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-community/slider": "^5.2.0",
    "@shopify/flash-list": "^2.3.1",
    "expo": "~56.0.3",
    "expo-async-fs": "file:./modules/expo-async-fs",
    "expo-backup-exclusions": "file:./modules/expo-backup-exclusions",
    "expo-battery": "~56.0.4",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.13",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.14",
    "expo-crypto": "~56.0.3",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-gzip": "file:./modules/expo-gzip",
    "expo-haptics": "~56.0.3",
    "expo-image-colors": "file:./modules/expo-image-colors",
    "expo-image-resize": "file:./modules/expo-image-resize",
    "expo-intent-launcher": "~56.0.4",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.11",
    "expo-localization": "~56.0.6",
    "expo-location": "~56.0.12",
    "expo-move-to-back": "file:./modules/expo-move-to-back",
    "expo-notifications": "~56.0.12",
    "expo-router": "~56.2.5",
    "expo-screen-orientation": "~56.0.5",
    "expo-sharing": "~56.0.12",
    "expo-sqlite": "~56.0.4",
    "expo-ssl-trust": "file:./modules/expo-ssl-trust",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "i18next": "^26.0.8",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^12.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.6",
    "react-native": "0.85.3",
    "react-native-bootsplash": "^7.3.1",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-reanimated": "^4.3.1",
    "react-native-reorderable-list": "^0.18.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-track-player": "file:./modules/react-native-track-player",
    "react-native-worklets": "^0.8.3",
    "subsonic-api": "file:./modules/subsonic-api",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "~29.5.14",
    "@types/react": "~19.2.14",
    "expo-dev-client": "~56.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.4",
    "patch-package": "^8.0.1",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "@react-native-community/netinfo",
        "@react-native-community/slider",
        "@shopify/flash-list",
        "react-native-bootsplash",
        "react-native-gesture-handler",
        "react-native-reanimated",
        "react-native-safe-area-context",
        "react-native-svg",
        "react-native-screens",
        "react-native-worklets",
        "subsonic-api"
      ]
    },
    "doctor": {
      "dependencies": {
        "exclude": [
          "@react-native-community/netinfo",
          "react-native-safe-area-context"
        ]
      },
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-track-player",
          "expo-async-fs",
          "expo-ssl-trust",
          "expo-backup-exclusions",
          "expo-gzip",
          "expo-move-to-back",
          "expo-image-resize",
          "expo-image-colors",
          "subsonic-api"
        ]
      }
    }
  }
}
